{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/auth/login", "destination": "/api/auth?action=login" },
    { "source": "/api/auth/register", "destination": "/api/auth?action=register" },
    { "source": "/api/auth/refresh", "destination": "/api/auth?action=refresh" },
    { "source": "/api/auth/logout", "destination": "/api/auth?action=logout" },
    { "source": "/api/stocks/search", "destination": "/api/stocks?action=search" },
    { "source": "/api/stocks/:symbol/price", "destination": "/api/stocks?action=price&symbol=:symbol" },
    { "source": "/api/stocks/:symbol/history", "destination": "/api/stocks?action=history&symbol=:symbol" },
    { "source": "/api/compare/shared/:token", "destination": "/api/compare/shared?token=:token" },
    { "source": "/api/portfolio/:id", "destination": "/api/portfolio/item?id=:id" },
    { "source": "/api/watchlist/:id", "destination": "/api/watchlist/item?id=:id" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
